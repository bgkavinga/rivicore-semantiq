<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="rivicore" translate="label" sortOrder="500">
            <label>Rivicore</label>
        </tab>

        <section id="rivicore_semantiq" translate="label" sortOrder="10"
                 showInDefault="1" showInWebsite="1" showInStore="1">
            <tab>rivicore</tab>
            <label>SemantiQ Semantic Search</label>
            <resource>Rivicore_SemantiQ::config</resource>

            <!-- ============================================================ -->
            <!-- General -->
            <!-- ============================================================ -->
            <group id="general" translate="label" sortOrder="10"
                   showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General Settings</label>

                <field id="enabled" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Enable SemantiQ</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>When enabled, storefront search is handled by the configured vector store. Falls back to Elasticsearch if an error occurs.</comment>
                </field>

                <field id="index_products" translate="label" type="select" sortOrder="20"
                       showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Index Products</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="index_cms_pages" translate="label" type="select" sortOrder="30"
                       showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Index CMS Pages</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="rag_enabled" translate="label" type="select" sortOrder="40"
                       showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Enable RAG (LLM Context)</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>When enabled, a summary context is generated by the configured LLM provider and dispatched via event for display.</comment>
                </field>

                <field id="index_attributes" translate="label" type="multiselect" sortOrder="50"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>Product Attributes to Index</label>
                    <source_model>Rivicore\SemantiQ\Model\Config\Source\ProductAttributes</source_model>
                    <comment>Selected attribute values are concatenated and embedded. Defaults to name and description.</comment>
                </field>

                <field id="search_result_size" translate="label" type="text" sortOrder="60"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>Max Search Results</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                    <comment>Maximum number of products returned by a vector search query.</comment>
                </field>

                <field id="min_score" translate="label" type="text" sortOrder="70"
                       showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Minimum Similarity Score</label>
                    <validate>validate-number</validate>
                    <comment>Results below this cosine similarity score are discarded. Range 0.0–1.0. Set to 0 to disable. Typical ranges: exact synonym ≥ 0.80, intent query ≥ 0.70, weak match ≥ 0.60, unrelated &lt; 0.60.</comment>
                </field>
            </group>

            <!-- ============================================================ -->
            <!-- Vector Store Backend -->
            <!-- ============================================================ -->
            <group id="vector_store" translate="label" sortOrder="20"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Vector Store Backend</label>

                <field id="backend" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>Backend</label>
                    <source_model>Rivicore\SemantiQ\Model\Config\Source\VectorBackend</source_model>
                </field>

                <!-- OpenSearch -->
                <field id="opensearch_index_name" translate="label" type="text" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>OpenSearch Index Name</label>
                    <depends><field id="backend">opensearch</field></depends>
                </field>

                <field id="opensearch_host" translate="label" type="text" sortOrder="25"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>OpenSearch Host (Vector Store)</label>
                    <depends><field id="backend">opensearch</field></depends>
                    <comment>Full URL of a dedicated OpenSearch instance for vector storage, e.g. https://vector-os:9200. Leave blank to reuse Magento's catalog search connection.</comment>
                </field>

                <field id="opensearch_username" translate="label" type="text" sortOrder="26"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>OpenSearch Username</label>
                    <depends><field id="backend">opensearch</field></depends>
                    <comment>Leave blank if the dedicated instance requires no authentication.</comment>
                </field>

                <field id="opensearch_password" translate="label" type="obscure" sortOrder="27"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>OpenSearch Password</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends><field id="backend">opensearch</field></depends>
                </field>

                <!-- ChromaDB -->
                <field id="chromadb_url" translate="label" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>ChromaDB URL</label>
                    <depends><field id="backend">chromadb</field></depends>
                    <comment>e.g. http://localhost:8000</comment>
                </field>

                <field id="chromadb_collection" translate="label" type="text" sortOrder="40"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>ChromaDB Collection Name</label>
                    <depends><field id="backend">chromadb</field></depends>
                </field>

                <!-- AWS Bedrock Knowledge Base -->
                <field id="bedrock_kb_region" translate="label" type="text" sortOrder="50"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>AWS Region</label>
                    <depends><field id="backend">bedrock_kb</field></depends>
                </field>

                <field id="bedrock_kb_id" translate="label" type="text" sortOrder="60"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Knowledge Base ID</label>
                    <depends><field id="backend">bedrock_kb</field></depends>
                </field>

                <field id="bedrock_kb_access_key" translate="label" type="obscure" sortOrder="70"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>AWS Access Key ID</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends><field id="backend">bedrock_kb</field></depends>
                </field>

                <field id="bedrock_kb_secret_key" translate="label" type="obscure" sortOrder="80"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>AWS Secret Access Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends><field id="backend">bedrock_kb</field></depends>
                </field>
            </group>

            <!-- ============================================================ -->
            <!-- Embedding Provider -->
            <!-- ============================================================ -->
            <group id="embedding" translate="label" sortOrder="30"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>Embedding Provider</label>

                <field id="provider" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>Provider</label>
                    <source_model>Rivicore\SemantiQ\Model\Config\Source\EmbeddingProvider</source_model>
                </field>

                <!-- OpenSearch ML Commons -->
                <field id="opensearch_ml_model_id" translate="label" type="text" sortOrder="15"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>OpenSearch ML Model ID</label>
                    <depends><field id="provider">opensearch</field></depends>
                    <comment>The deployed ML Commons model ID, e.g. "bQ1J8ooBpBj3wT4HVemV". Find it via GET /_plugins/_ml/models/_search.</comment>
                </field>

                <field id="opensearch_ml_dimension" translate="label" type="text" sortOrder="16"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>Embedding Dimension</label>
                    <depends><field id="provider">opensearch</field></depends>
                    <validate>validate-digits validate-greater-than-zero</validate>
                    <comment>Must match the output dimension of the deployed model (e.g. 768 for SBERT, 1536 for OpenAI-style models).</comment>
                </field>

                <!-- OpenAI -->
                <field id="openai_api_key" translate="label" type="obscure" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>OpenAI API Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends><field id="provider">openai</field></depends>
                </field>

                <field id="openai_model" translate="label" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>OpenAI Embedding Model</label>
                    <depends><field id="provider">openai</field></depends>
                </field>

                <!-- AWS Bedrock -->
                <field id="bedrock_region" translate="label" type="text" sortOrder="40"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>AWS Region</label>
                    <depends><field id="provider">bedrock</field></depends>
                </field>

                <field id="bedrock_model" translate="label" type="text" sortOrder="50"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>Bedrock Embedding Model ID</label>
                    <depends><field id="provider">bedrock</field></depends>
                </field>

                <field id="bedrock_access_key" translate="label" type="obscure" sortOrder="60"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>AWS Access Key ID</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends><field id="provider">bedrock</field></depends>
                </field>

                <field id="bedrock_secret_key" translate="label" type="obscure" sortOrder="70"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>AWS Secret Access Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends><field id="provider">bedrock</field></depends>
                </field>

                <!-- Ollama -->
                <field id="ollama_base_url" translate="label" type="text" sortOrder="80"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>Ollama Base URL</label>
                    <depends><field id="provider">ollama</field></depends>
                </field>

                <field id="ollama_model" translate="label" type="text" sortOrder="90"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>Ollama Embedding Model</label>
                    <depends><field id="provider">ollama</field></depends>
                </field>

                <!-- Anthropic -->
                <field id="anthropic_api_key" translate="label" type="obscure" sortOrder="100"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Anthropic API Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends><field id="provider">anthropic</field></depends>
                </field>

                <field id="anthropic_model" translate="label" type="text" sortOrder="110"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>Anthropic Model</label>
                    <comment>Experimental: Anthropic has no dedicated embedding API. A Claude model call is used to produce embedding text.</comment>
                    <depends><field id="provider">anthropic</field></depends>
                </field>
            </group>

            <!-- ============================================================ -->
            <!-- LLM Provider (RAG) -->
            <!-- ============================================================ -->
            <group id="llm" translate="label" sortOrder="40"
                   showInDefault="1" showInWebsite="0" showInStore="0">
                <label>LLM Provider (RAG)</label>

                <field id="llm_provider" translate="label" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>Provider</label>
                    <source_model>Rivicore\SemantiQ\Model\Config\Source\LlmProvider</source_model>
                </field>

                <!-- OpenAI -->
                <field id="llm_openai_api_key" translate="label" type="obscure" sortOrder="20"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>OpenAI API Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends><field id="llm_provider">openai</field></depends>
                </field>

                <field id="llm_openai_model" translate="label" type="text" sortOrder="30"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>OpenAI Chat Model</label>
                    <depends><field id="llm_provider">openai</field></depends>
                </field>

                <!-- AWS Bedrock -->
                <field id="llm_bedrock_region" translate="label" type="text" sortOrder="40"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>AWS Region</label>
                    <depends><field id="llm_provider">bedrock</field></depends>
                </field>

                <field id="llm_bedrock_model" translate="label" type="text" sortOrder="50"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>Bedrock Model ID</label>
                    <depends><field id="llm_provider">bedrock</field></depends>
                </field>

                <field id="llm_bedrock_access_key" translate="label" type="obscure" sortOrder="60"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>AWS Access Key ID</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends><field id="llm_provider">bedrock</field></depends>
                </field>

                <field id="llm_bedrock_secret_key" translate="label" type="obscure" sortOrder="70"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>AWS Secret Access Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends><field id="llm_provider">bedrock</field></depends>
                </field>

                <!-- Ollama -->
                <field id="llm_ollama_base_url" translate="label" type="text" sortOrder="80"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>Ollama Base URL</label>
                    <depends><field id="llm_provider">ollama</field></depends>
                </field>

                <field id="llm_ollama_model" translate="label" type="text" sortOrder="90"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>Ollama Chat Model</label>
                    <depends><field id="llm_provider">ollama</field></depends>
                </field>

                <!-- Anthropic -->
                <field id="llm_anthropic_api_key" translate="label" type="obscure" sortOrder="100"
                       showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Anthropic API Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <depends><field id="llm_provider">anthropic</field></depends>
                </field>

                <field id="llm_anthropic_model" translate="label" type="text" sortOrder="110"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>Anthropic Model</label>
                    <depends><field id="llm_provider">anthropic</field></depends>
                </field>

                <!-- Shared RAG options -->
                <field id="rag_max_context_docs" translate="label" type="text" sortOrder="200"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>Max Context Documents</label>
                    <validate>validate-digits validate-greater-than-zero</validate>
                    <comment>Number of top vector results sent to the LLM as context.</comment>
                </field>

                <field id="rag_prompt_template" translate="label" type="textarea" sortOrder="210"
                       showInDefault="1" showInWebsite="0" showInStore="0" canRestore="1">
                    <label>RAG Prompt Template</label>
                    <comment>Use {{query}} for the user query and {{context}} for the product context block.</comment>
                </field>
            </group>

        </section>
    </system>
</config>
